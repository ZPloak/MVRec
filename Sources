-- Button Connections
-- =============================================
SetTargetButton.MouseButton1Click:Connect(setTarget)
RecordButton.MouseButton1Click:Connect(startRecording)
StopRecordButton.MouseButton1Click:Connect(stopRecording)
PlayButton.MouseButton1Click:Connect(startPlayback)
StopPlayButton.MouseButton1Click:Connect(stopPlayback)
CopyButton.MouseButton1Click:Connect(copyToClipboard)
ClearButton.MouseButton1Click:Connect(clearRecording)
ModeToggle.MouseButton1Click:Connect(toggleMode)

-- Cleanup
player.CharacterAdded:Connect(function()
	if isRecording then stopRecording() end
	if isPlaying then stopPlayback() end
end)

ScreenGui.Destroying:Connect(function()
	if radiusCircle then
		radiusCircle:Destroy()
	end
end)

updateDisplay()
